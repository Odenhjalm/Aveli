{
    "system": {
        "name": "Aveli",
        "type": "social_learning_platform",
        "product_identity": "social_learning_platform_with_marketplace",
        "core_principles": {
            "relationship_driven": true,
            "experience_driven": true,
            "progression_based": true
        }
    },
    "decision_priority": [
        "system_laws",
        "constraints",
        "component_state",
        "runtime_code",
        "documentation"
    ],
    "governance": {
        "semantic_truth": "Aveli_System_Decisions.md",
        "execution_rules": "aveli_system_manifest.json",
        "api_audit_role": "runtime_observation_for_verification_not_automatic_legitimacy"
    },
    "components": {
        "api_layer": {
            "source_of_truth": [
                "docs/audit/20260109_aveli_visdom_audit/API_CATALOG.json",
                "docs/audit/20260109_aveli_visdom_audit/API_USAGE_DIFF.md"
            ],
            "state": "runtime_observed",
            "mutation_policy": "alignment_only",
            "audit_interpretation": "observed_reality_not_automatic_canonical_truth"
        },
        "media_control_plane": {
            "source_of_truth": [
                "docs/media_control_plane_mcp.md",
                "docs/media_architecture.md"
            ],
            "state": "planned_protected",
            "protected": true,
            "mutation_policy": "no_modification_or_redefinition",
            "role": "media_intent_authority"
        },
        "media_pipeline": {
            "state": "runtime_active",
            "role": "implementation_layer",
            "mutation_policy": "alignment_only",
            "playback_authority": "runtime_media",
            "home_player_runtime_model": {
                "same_media_domain": true,
                "has_separate_upload_pipeline": true,
                "has_separate_frontend_management_surface": true,
                "teacher_curated_active_state": true,
                "curation_authority": "control_plane",
                "playback_projection": "runtime_media_only",
                "alternative_playback_paths": "forbidden",
                "direct_storage_playback": "forbidden"
            }
        },
        "auth": {
            "state": "runtime_active",
            "mutation_policy": "no_structural_change",
            "constraints": [
                "trust_boundary",
                "no_flow_redesign"
            ]
        },
        "editor": {
            "state": "runtime_partial",
            "mutation_policy": "constraint_enforcement_only",
            "constraints": [
                "canonical_markdown_required"
            ]
        },
        "course_model": {
            "state": "canonical_flat_hierarchy",
            "source_of_truth": [
                "Aveli_System_Decisions.md",
                "backend/app/routes/courses.py",
                "frontend/lib/features/courses/data/courses_repository.dart",
                "courses/_template.yaml"
            ],
            "canonical_structure": {
                "hierarchy": "course_to_lessons",
                "lesson_ordering": "position",
                "lesson_display_name": "lesson_title",
                "course_progression_field": "step",
                "course_grouping_field": "course_group_id",
                "grouping_authority": "course_group_id_only",
                "grouping_semantics": "progression_set_ordered_by_step",
                "non_progression_grouping": "forbidden",
                "grouping": "course_group_id_explicit_only",
                "runtime_title_or_slug_inference": "forbidden"
            },
            "forbidden_constructs": [
                "module",
                "intermediate_grouping_layer",
                "virtual_grouping_layer",
                "simulated_grouping_layer",
                "inferred_grouping_layer"
            ],
            "mutation_policy": "flat_hierarchy_only"
        },
        "access_model": {
            "state": "runtime_canonical",
            "app_access_authority": "memberships",
            "course_access_authority": "course_enrollments",
            "membership_scope": "global",
            "membership_required_for_app_entry": true,
            "course_access_requires_enrollment_row": true,
            "intro_access_requires_enrollment_row": true,
            "standard_course_access_via_membership_alone": false,
            "intro_enrollment_source": "intro_enrollment",
            "purchase_enrollment_source": "purchase",
            "implicit_course_access": false,
            "drip_model": {
                "applies_only_to_source": "intro_enrollment",
                "stored_state_only": true,
                "scheduler": "worker_only",
                "execution_mode": "cron_based",
                "state_updates": "worker_only",
                "lazy_runtime_unlock_evaluation": false,
                "runtime_drip_updates": "forbidden",
                "frontend_drip_logic": "forbidden",
                "unlock_anchor": "drip_started_at",
                "unlock_index": "current_unlock_position",
                "lesson_progression_index": "position",
                "default_interval_days": 7,
                "initial_unlock_state": {
                    "intro_enrollment_with_lessons": 1,
                    "intro_enrollment_with_zero_lessons": 0,
                    "intro_enrollment_drip_started_at": "granted_at",
                    "purchase_drip_started_at": null,
                    "purchase_current_unlock_position": null
                },
                "advance_formula": {
                    "unlocked_count": "1 + floor((now - drip_started_at) / interval)",
                    "interval_days": 7,
                    "computed_unlock_position": "min(max_lesson_position, unlocked_count)"
                },
                "clamp_behavior": {
                    "never_exceed_max_lesson_position": true,
                    "max_reached_is_no_op": true
                },
                "idempotence": {
                    "deterministic_runs": true,
                    "same_cron_window_same_result": true,
                    "update_only_when_computed_gt_stored": true,
                    "never_decrease_current_unlock_position": true
                }
            },
            "checkout_outcomes": [
                "membership",
                "course_enrollment",
                "both"
            ]
        }
    },
    "authorities": {
        "media_authority_model": "split_intent_and_playback",
        "app_access_authority": "memberships",
        "course_access_authority": "course_enrollments",
        "playback_authority": "runtime_media",
        "media_intent_authority": "control_plane"
    },
    "external_dependencies": [
        "auth.users",
        "storage.objects",
        "storage.buckets"
    ],
    "external_reference_policy": {
        "enforcement": "application_layer",
        "database_fk": "forbidden",
        "read_behavior": "tolerant"
    },
    "local_verification_dependencies": {
        "external_dependencies_are_not_baseline_owned_schema": true,
        "storage_backed_worker_scratch_verification_may_require_minimal_local_storage_substrate": true
    },
    "legacy_migration_policy": {
        "legacy_remains_only_while_needed": true,
        "canonical_coverage_triggers_migration_out": true,
        "fallback_forbidden": true,
        "removal_requires_clear_replacement": true,
        "removal_sequence": [
            "replacement_exists",
            "legacy_surface_identified",
            "legacy_surface_blocked_or_logged",
            "legacy_surface_removed"
        ]
    },
    "current_runtime_focus": [
        "lesson_editor",
        "lesson_view",
        "stripe_checkout",
        "onboarding",
        "membership_gated_app_entry",
        "canonical_course_access",
        "home_player_curation_and_playback_compliance"
    ],
    "future_facing_surfaces": [
        "activities",
        "posts",
        "messages",
        "notifications"
    ],
    "canonical_media_resolution_path": {
        "reference_chain": [
            "lesson_content_markdown:lesson_media_id",
            "lesson_media",
            "control_plane",
            "storage.objects",
            "runtime_media",
            "playback_api",
            "client"
        ],
        "laws": {
            "runtime_media_only_playback_authority": true,
            "storage_objects_never_valid_playback_source": true,
            "control_plane_intent_not_playback": true,
            "runtime_media_bypass_forbidden": true,
            "lesson_content_media_references_use_lesson_media_id_only": true,
            "fallback_forbidden": true
        },
        "home_player": {
            "same_media_domain": true,
            "separate_upload_pipeline_allowed": true,
            "separate_frontend_management_surface_allowed": true,
            "curation_controlled_by": "control_plane",
            "playback_must_resolve_through_runtime_media": true,
            "alternative_playback_paths_forbidden": true,
            "direct_storage_playback_forbidden": true
        }
    },
    "canonical_language_rules": {
        "membership": "canonical_app_access_term",
        "course_enrollments": "canonical_course_access_term",
        "subscription": "legacy_or_migration_only",
        "module": "forbidden_runtime_domain_term"
    },
    "rules": {
        "api_truth": "audit_is_observation_not_automatic_legitimacy",
        "media_authority_model": "split_intent_and_playback",
        "app_access_authority": "memberships",
        "course_access_authority": "course_enrollments",
        "no_access_without_enrollment_row": true,
        "intro_access_requires_enrollment_row": true,
        "no_lesson_access_beyond_current_unlock_position": true,
        "no_fallback_unlock_logic": true,
        "no_title_or_slug_based_progression": true,
        "no_runtime_inference_of_access_or_unlock_state": true,
        "grouping_authority": "course_group_id_only",
        "grouping_semantics": "progression_set_ordered_by_step",
        "non_progression_grouping": "forbidden",
        "drip_scheduler": "worker_only",
        "drip_execution_mode": "cron_based",
        "drip_state_updates": "worker_only",
        "runtime_drip_updates": "forbidden",
        "frontend_drip_logic": "forbidden",
        "drip_interval_days": 7,
        "drip_initial_unlock_intro_with_lessons": 1,
        "drip_initial_unlock_intro_with_zero_lessons": 0,
        "drip_initial_anchor": "granted_at",
        "purchase_drip_started_at": "must_be_null",
        "purchase_current_unlock_position": "must_be_null",
        "drip_formula_unlocked_count": "1 + floor((now - drip_started_at) / interval)",
        "drip_formula_computed_unlock_position": "min(max_lesson_position, unlocked_count)",
        "drip_clamp_to_max_lesson_position": true,
        "drip_no_op_when_max_reached": true,
        "drip_runs_must_be_deterministic": true,
        "drip_same_cron_window_same_result": true,
        "drip_update_only_when_computed_gt_stored": true,
        "drip_never_decrease_current_unlock_position": true,
        "playback_authority": "runtime_media",
        "media_intent_authority": "control_plane",
        "media_authority_enforcement": "all_playback_must_resolve_through_runtime_media",
        "all_audio_must_pass_worker_pipeline": true,
        "wav_must_become_mp3_before_ready": true,
        "direct_audio_ready_writes": "forbidden",
        "storage_objects_playback_source": "forbidden",
        "runtime_media_bypass": "forbidden",
        "lesson_content_media_reference": "lesson_media_id_only",
        "content_format": "canonical_markdown",
        "auth_behavior": "trust_boundary",
        "course_structure": "course_to_lessons_direct",
        "lesson_ordering": "position",
        "lesson_display_name": "lesson_title",
        "course_progression_field": "step",
        "course_grouping_field": "course_group_id",
        "feature_expansion_model": "new_entities_only",
        "core_domain_entities": [
            "courses",
            "lessons",
            "course_enrollments",
            "media_assets",
            "lesson_media"
        ],
        "core_domain_mutation_for_features": "forbidden",
        "feature_attachment_strategy": "external_entities_only",
        "module_abstraction": "forbidden",
        "fallback": "forbidden",
        "one_path_per_concept": true,
        "multiple_paths_make_system_invalid": true,
        "missing_data_must_fail_never_infer": true
    },
    "forbidden_surfaces": {
        "terms": [
            "subscription",
            "module"
        ],
        "authorities": [
            "duplicate_app_access_authority",
            "duplicate_normal_course_access_authority",
            "implicit_intro_access",
            "legacy_entitlement_fallback",
            "step_based_ownership_logic",
            "runtime_derived_progression",
            "runtime_derived_unlock_state",
            "implicit_course_access_by_tag_or_inference",
            "storage_as_business_truth"
        ],
        "media_patterns": [
            "direct_storage_playback",
            "alternate_playback_authority",
            "runtime_media_bypass",
            "legacy_playback_fallback"
        ],
        "api_patterns": [
            "returns_storage_path_as_canonical_playback_identity",
            "returns_object_url_as_canonical_playback_identity",
            "duplicates_membership_logic",
            "duplicates_enrollment_logic"
        ]
    },
    "constraints": {
        "no_deletion_of_planned_features": true,
        "no_modification_of_control_plane": true,
        "control_plane_redefinition_forbidden": true,
        "auth_no_structural_change": true,
        "no_assumption_rule": true,
        "flat_course_hierarchy_enforced": true,
        "no_simulated_grouping_layers": true,
        "no_inferred_grouping_layers": true,
        "fallback_forbidden": true,
        "legacy_removal_requires_replacement": true
    },
    "execution_policy": {
        "step_by_step": true,
        "verification_required": true,
        "stop_on_ambiguity": true,
        "no_implicit_decisions": true
    }
}
