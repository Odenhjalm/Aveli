            "studio_lesson_media_edge": "separate_for_authoring_and_pipeline_interaction",
            "media_assets_never_defines_access": true,
            "intro_lesson_content_surface_access_rule": "requires source = intro_enrollment AND course_enrollments AND lesson.position <= current_unlock_position",
