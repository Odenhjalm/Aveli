                "rule": [
                    "course_enrollments",
                    "lesson.position <= current_unlock_position"
                ],
                "current_unlock_position_source": "course_enrollments.current_unlock_position"
            },
            "lesson_content_surface_access_rule": "requires course_enrollments AND lesson.position <= current_unlock_position",
            "lesson_media_only_inside_lesson_content_surface": true,
