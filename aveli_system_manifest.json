{
    "system": {
        "name": "Aveli",
        "type": "social_learning_platform",
        "product_identity": "social_learning_platform_with_marketplace",
        "core_principles": {
            "relationship_driven": true,
            "experience_driven": true,
            "progression_based": true
        }
    },
    "decision_priority": [
        "system_laws",
        "constraints",
        "component_state",
        "runtime_code",
        "documentation"
    ],
    "components": {
        "api_layer": {
            "source_of_truth": [
                "docs/audit/20260109_aveli_visdom_audit/API_CATALOG.json",
                "docs/audit/20260109_aveli_visdom_audit/API_USAGE_DIFF.md"
            ],
            "state": "runtime_active",
            "mutation_policy": "alignment_only"
        },
        "media_control_plane": {
            "source_of_truth": [
                "docs/media_control_plane_mcp.md",
                "docs/media_architecture.md"
            ],
            "state": "planned_protected",
            "protected": true,
            "mutation_policy": "no_modification"
        },
        "media_pipeline": {
            "state": "runtime_active",
            "role": "implementation_layer",
            "mutation_policy": "alignment_only",
            "home_player_runtime_model": {
                "source_storage_truth": "separate_from_runtime_media",
                "playback_projection": "runtime_media_only",
                "alternative_playback_paths": "forbidden"
            }
        },
        "auth": {
            "state": "runtime_active",
            "mutation_policy": "no_structural_change",
            "constraints": [
                "trust_boundary",
                "no_flow_redesign"
            ]
        },
        "editor": {
            "state": "runtime_partial",
            "mutation_policy": "constraint_enforcement_only",
            "constraints": [
                "canonical_markdown_required"
            ]
        },
        "course_model": {
            "state": "canonical_flat_hierarchy",
            "source_of_truth": [
                "actual_truth_2026-04-26/Aveli_System_Decisions.md",
                "backend/app/routes/courses.py",
                "frontend/lib/features/courses/data/courses_repository.dart",
                "courses/_template.yaml"
            ],
            "canonical_structure": {
                "hierarchy": "course_to_lessons",
                "lesson_ordering": "position",
                "grouping": "ui_only_optional"
            },
            "forbidden_constructs": [
                "intermediate_grouping_layer",
                "virtual_grouping_layer",
                "simulated_grouping_layer",
                "inferred_grouping_layer"
            ],
            "mutation_policy": "flat_hierarchy_only"
        }
    },
    "authorities": {
        "media_authority_model": "split_intent_and_playback",
        "course_access_authority": "enrollments",
        "subscription_state_authority": "memberships",
        "playback_authority": "runtime_media",
        "media_intent_authority": "control_plane"
    },
    "external_dependencies": [
        "auth.users",
        "storage.objects",
        "storage.buckets"
    ],
    "external_reference_policy": {
        "enforcement": "application_layer",
        "database_fk": "forbidden",
        "read_behavior": "tolerant"
    },
    "local_verification_dependencies": {
        "external_dependencies_are_not_baseline_owned_schema": true,
        "storage_backed_worker_scratch_verification_may_require_minimal_local_storage_substrate": true
    },
    "legacy_migration_policy": {
        "legacy_remains_only_while_needed": true,
        "canonical_coverage_triggers_migration_out": true
    },
    "current_runtime_focus": [
        "lesson_editor",
        "lesson_view",
        "stripe_checkout",
        "onboarding"
    ],
    "future_facing_surfaces": [
        "activities",
        "posts",
        "messages",
        "notifications"
    ],
    "canonical_media_resolution_path": {
        "reference_chain": [
            "lesson_content_markdown:lesson_media_id",
            "lesson_media",
            "control_plane",
            "storage.objects",
            "runtime_media",
            "playback_api",
            "client"
        ],
        "laws": {
            "runtime_media_only_playback_authority": true,
            "storage_objects_never_valid_playback_source": true,
            "control_plane_intent_not_playback": true,
            "runtime_media_bypass_forbidden": true,
            "lesson_content_media_references_use_lesson_media_id_only": true
        },
        "home_player": {
            "source_storage_truth": "separate_allowed",
            "playback_must_resolve_through_runtime_media": true,
            "alternative_playback_paths_forbidden": true
        }
    },
    "rules": {
        "api_truth": "audit_over_spec",
        "media_authority_model": "split_intent_and_playback",
        "course_access_authority": "enrollments",
        "subscription_state_authority": "memberships",
        "playback_authority": "runtime_media",
        "media_intent_authority": "control_plane",
        "media_authority_enforcement": "all_playback_must_resolve_through_runtime_media",
        "storage_objects_playback_source": "forbidden",
        "runtime_media_bypass": "forbidden",
        "lesson_content_media_reference": "lesson_media_id_only",
        "content_format": "canonical_markdown",
        "auth_behavior": "trust_boundary",
        "course_structure": "course_to_lessons_direct",
        "lesson_ordering": "position",
        "module_abstraction": "forbidden",
        "intermediate_grouping_layer": "forbidden"
    },
    "constraints": {
        "no_deletion_of_planned_features": true,
        "no_modification_of_control_plane": true,
        "auth_no_structural_change": true,
        "no_assumption_rule": true,
        "flat_course_hierarchy_enforced": true,
        "no_simulated_grouping_layers": true,
        "no_inferred_grouping_layers": true
    },
    "execution_policy": {
        "step_by_step": true,
        "verification_required": true,
        "stop_on_ambiguity": true,
        "no_implicit_decisions": true
    }
}
